---
const { eyebrow, title, subtitle, align = 'left', titleClass = '', eyebrowClass = '' } = Astro.props;
const alignClass = align === 'center' ? 'text-center items-center' : 'text-left items-start';
---
<div class={`flex flex-col gap-3 ${alignClass}`}>
  {eyebrow && (
    <span class={`mobile-eyebrow text-xs font-semibold uppercase text-gold ${eyebrowClass}`}>
      {eyebrow}
    </span>
  )}
  <h2 class={`font-display text-2xl leading-tight sm:text-4xl lg:text-5xl ${titleClass}`}>
    {title}
  </h2>
  {subtitle && <p class="max-w-2xl text-sm text-cocoa/85">{subtitle}</p>}
</div>
