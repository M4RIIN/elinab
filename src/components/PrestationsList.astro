---
const { items = [] } = Astro.props;
---
<div class="grid gap-6 md:grid-cols-2">
  {items.map((item) => (
    <article class="rounded-2xl border border-gold/35 bg-[linear-gradient(165deg,_rgba(255,255,255,0.9),_rgba(247,244,238,0.78))] p-6 shadow-soft transition duration-300 hover:-translate-y-1 hover:border-gold/60 hover:shadow-lift">
      {(item.duration || item.price) && (
        <div class="mobile-eyebrow flex flex-wrap items-center justify-between gap-2 text-xs uppercase text-cocoa/75">
          <span>{item.duration}</span>
          <span class="text-gold">{item.price}</span>
        </div>
      )}
      <h3 class="mt-4 font-display text-xl sm:text-2xl">{item.name}</h3>
      {item.category && <p class="mt-3 text-sm text-cocoa/80">{item.category}</p>}
      {typeof item.description === 'string' && item.description && (
        <p class="mt-3 text-sm text-cocoa/80">{item.description}</p>
      )}
      {Array.isArray(item.description) && item.description.length > 0 && (
        <div class="mt-4 space-y-3 text-sm text-cocoa/80">
          {item.description.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
      )}
    </article>
  ))}
</div>
