---
const { formation, className = '' } = Astro.props;
---
<article id={formation.id} class={`${className} rounded-2xl border border-gold/35 bg-[linear-gradient(165deg,_rgba(255,255,255,0.9),_rgba(247,244,238,0.78))] p-6 shadow-soft transition duration-300 hover:-translate-y-1 hover:border-gold/60 hover:shadow-lift`}>
  {(formation.duration || formation.price) && (
    <div class="mobile-eyebrow flex flex-wrap items-center justify-between gap-2 text-xs uppercase text-cocoa/75">
      <span>{formation.duration}</span>
      <span class="text-gold">{formation.price}</span>
    </div>
  )}
  <h3 class="mt-4 font-display text-xl sm:text-2xl">{formation.name}</h3>
  {formation.category && <p class="mt-3 text-sm text-cocoa/80">{formation.category}</p>}
  {formation.description && <p class="mt-3 text-sm text-cocoa/80">{formation.description}</p>}
  {(formation.format || formation.location) && (
    <div class="mobile-eyebrow mt-4 flex flex-wrap gap-3 text-xs uppercase text-cocoa/70">
      {formation.format && <span>{formation.format}</span>}
      {formation.location && <span>{formation.location}</span>}
    </div>
  )}
  {formation.path && (
    <a href={formation.path} class="mt-5 inline-flex text-xs font-semibold uppercase tracking-[0.14em] text-gold hover:text-ink">
      Voir sur la page formations
    </a>
  )}
</article>
