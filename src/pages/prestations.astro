---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import PrestationsList from '../components/PrestationsList.astro';
import CTASection from '../components/CTASection.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

import { prestations } from '../data/catalog';
import { getAbsoluteUrl, siteConfig } from '../data/site';

const categoryOrder = ['Beauté du regard', 'Soins du visage', 'Maquillage semi-permanent', 'Soins corps'];
const prestationsByCategory = categoryOrder.map((category) => ({
  category,
  items: prestations.filter((prestation) => prestation.category === category)
}));
const prestationsFaqs = [
  {
    question: 'Les tarifs affiches correspondent-ils a la seance ?',
    answer: 'Oui, les prix affiches sont presentes par prestation standard. Un protocole ou une cure sur-mesure peut faire l objet d un devis.',
  },
  {
    question: 'Dans quelle zone intervenez-vous ?',
    answer: `Le site s adresse principalement aux clientes de ${siteConfig.city}, Toulouse et des communes voisines.`,
  },
  {
    question: 'Comment reserver une prestation ?',
    answer: 'Vous pouvez utiliser la page contact pour demander un rendez-vous, poser une question ou obtenir une orientation vers le soin adapte.',
  },
];
const prestationsSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `Prestations esthetiques a ${siteConfig.city}`,
  itemListElement: prestations.map((prestation, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: getAbsoluteUrl(prestation.path),
    name: prestation.name,
  })),
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: prestationsFaqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---
<BaseLayout
  title={`Prestations esthetiques a ${siteConfig.city} | ${siteConfig.brandName}`}
  description={`Prestations esthetiques a ${siteConfig.city}, pres de Toulouse : beaute du regard, soins du visage, maquillage semi-permanent et soins corps sur-mesure.`}
  keywords="prestations esthetiques saint-orens-de-gameville, rehaussement de cils toulouse, browlift saint-orens, drainage bresilien toulouse"
  schema={[prestationsSchema, faqSchema]}
>
  <section class="container-shell py-20">
    <SectionTitle
      eyebrow="Prestations"
      title="Prestations esthetiques sur-mesure"
      subtitle={`Des soins proposes a ${siteConfig.city}, penses pour des besoins reels, avec tarifs visibles, zone desservie et contact direct.`}
    />
    <div class="mobile-eyebrow mt-6 flex flex-wrap gap-3 text-xs uppercase text-cocoa/70">
      {categoryOrder.map((category) => (
        <span class="rounded-full border border-gold/40 px-4 py-2">{category}</span>
      ))}
    </div>
    <p class="mt-6 max-w-3xl text-sm text-cocoa/80">
      Chaque prestation comprend un intitulé clair, un tarif et un descriptif utile. Cela renforce la lisibilite
      pour Google et aide les clientes a identifier rapidement le soin qui correspond a leur besoin.
    </p>
    <div class="mt-8 grid gap-6 md:grid-cols-2">
      <article class="rounded-2xl border border-gold/35 bg-white/80 p-6 shadow-soft">
        <p class="mobile-eyebrow text-xs font-semibold uppercase text-gold">Expertise</p>
        <h2 class="mt-3 font-display text-2xl">Savoir-faire confirme</h2>
        <p class="mt-3 text-sm text-cocoa/80">Experience, protocoles personnalises et recherche d un rendu propre, durable et naturel.</p>
      </article>
      <article class="rounded-2xl border border-gold/35 bg-white/80 p-6 shadow-soft">
        <p class="mobile-eyebrow text-xs font-semibold uppercase text-gold">Zone</p>
        <h2 class="mt-3 font-display text-2xl">Clientele locale</h2>
        <p class="mt-3 text-sm text-cocoa/80">Positionnement local sur {siteConfig.city}, Toulouse et les communes voisines pour capter la recherche de proximite.</p>
      </article>
    </div>
    <div class="mt-10 grid gap-12">
      {prestationsByCategory.map((group) => (
        <div class="grid gap-6">
          <div class="flex flex-wrap items-center gap-3 sm:gap-4">
            <span class="mobile-eyebrow text-xs font-semibold uppercase text-gold">Catégorie</span>
            <h2 class="font-display text-2xl sm:text-3xl">{group.category}</h2>
          </div>
          <PrestationsList items={group.items} />
        </div>
      ))}
    </div>
  </section>

  <FAQAccordion
    faqs={prestationsFaqs}
    title="FAQ prestations"
    subtitle="Reponses rapides sur les tarifs, la zone desservie et la prise de rendez-vous."
  />

  <section class="container-shell py-20">
    <CTASection
      title="Reserver votre soin ou demander un avis"
      subtitle="Contactez-moi pour planifier votre prestation, valider le bon protocole ou demander un devis pour une cure."
      primaryLabel="Prendre rendez-vous"
      primaryHref="/contact"
      secondaryLabel="Voir les formations"
      secondaryHref="/formations"
    />
  </section>
</BaseLayout>
