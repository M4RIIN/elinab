---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import PrestationsList from '../components/PrestationsList.astro';
import CTASection from '../components/CTASection.astro';

import prestations from '../data/prestations.json';

const categoryOrder = ['Beauté du regard', 'Soins du visage', 'Maquillage semi-permanent', 'Soins corps'];
const prestationsByCategory = categoryOrder.map((category) => ({
  category,
  items: prestations.filter((prestation) => prestation.category === category)
}));
---
<BaseLayout
  title="Prestations — Elodie Mignot"
  description="Prestations esthétiques sur-mesure à Saint-Orens-de-Gameville près de Toulouse : visage, regard, dermopigmentation, soins corps."
  keywords="esthétique, beauté du regard, soin du visage, anti-âge, browlift, maquillage semi-permanent, dermopigmentation, micropigmentation, épilation, massage, minceur, drainage brésilien, rehaussement de cils, Toulouse, Saint-Orens-de-Gameville"
>
  <section class="container-shell py-20">
    <SectionTitle
      eyebrow="Prestations"
      title="Des soins signatures pour chaque besoin"
      subtitle="Des prestations personnalisées, réalisées avec précision et exigence."
    />
    <div class="mobile-eyebrow mt-6 flex flex-wrap gap-3 text-xs uppercase text-cocoa/70">
      {categoryOrder.map((category) => (
        <span class="rounded-full border border-gold/40 px-4 py-2">{category}</span>
      ))}
    </div>
    <p class="mt-6 max-w-3xl text-sm text-cocoa/80">
      Prestations d'esthétique à Toulouse et alentours : beauté du regard, soin du visage anti-âge, browlift,
      rehaussement de cils, maquillage semi-permanent, dermopigmentation et micropigmentation, épilation, massage,
      minceur et drainage brésilien.
    </p>
    <div class="mt-10 grid gap-12">
      {prestationsByCategory.map((group) => (
        <div class="grid gap-6">
          <div class="flex flex-wrap items-center gap-3 sm:gap-4">
            <span class="mobile-eyebrow text-xs font-semibold uppercase text-gold">Catégorie</span>
            <h2 class="font-display text-2xl sm:text-3xl">{group.category}</h2>
          </div>
          <PrestationsList items={group.items} />
        </div>
      ))}
    </div>
  </section>

  <section class="container-shell py-20">
    <CTASection
      title="Réserver votre soin"
      subtitle="Contactez-moi pour planifier votre prestation ou créer un protocole sur-mesure."
      primaryLabel="Prendre rendez-vous"
      primaryHref="/contact"
      secondaryLabel="Voir les formations"
      secondaryHref="/formations"
    />
  </section>
</BaseLayout>
